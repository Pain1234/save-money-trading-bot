# Python paper-trading worker and read-only API image
FROM python:3.12-slim-bookworm AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --uid 10001 paper

WORKDIR /app

COPY pyproject.toml alembic.ini ./
COPY migrations ./migrations
COPY services ./services
COPY scripts ./scripts
COPY deploy/scripts ./deploy/scripts

RUN pip install --upgrade pip \
    && pip install -e ".[api]"

RUN chmod +x deploy/scripts/*.sh \
    && chown -R paper:paper /app

USER paper

# Default command overridden per Railway service (worker vs api)
CMD ["deploy/scripts/start-worker.sh"]
