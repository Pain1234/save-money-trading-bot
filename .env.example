HYPERLIQUID_NETWORK=testnet
HYPERLIQUID_HTTP_TIMEOUT_SECONDS=10
HYPERLIQUID_HEARTBEAT_INTERVAL_SECONDS=30
HYPERLIQUID_RECONNECT_INITIAL_SECONDS=1
HYPERLIQUID_RECONNECT_MAX_SECONDS=30
HYPERLIQUID_MAX_HTTP_CONCURRENCY=2
RUN_HYPERLIQUID_LIVE_TESTS=0

# Paper trading orchestrator (local PostgreSQL test only)
# PAPER_TRADING_DATABASE_URL=postgresql+psycopg://paper_trading_test:<LOCAL_TEST_PASSWORD>@localhost:5432/paper_trading_test
# PAPER_CONTROL_API_ENABLED=false
# PAPER_CONTROL_API_KEY=
# PAPER_CONTROL_API_LOCALHOST_ONLY=false
# PAPER_PRODUCTION_MODE=false

# Backend-only credential shared by Research API and dashboard BFF
# RESEARCH_WRITE_API_KEY (required; set to a random secret)
