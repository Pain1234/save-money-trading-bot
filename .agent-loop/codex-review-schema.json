{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Pain1234/save-money-trading-bot/schemas/codex-review-result-1.0.json",
  "title": "Codex review result",
  "description": "Contract 1.0 for read-only Codex review gate output. APPROVED must not contain BLOCKER/MAJOR findings (enforced in Python by validate-review-result.py). CHANGES_REQUIRED requires at least one BLOCKER or MAJOR (also enforced in Python).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict",
    "reviewed_base",
    "reviewed_head",
    "reviewed_diff_hash",
    "summary",
    "findings",
    "required_tests",
    "review_notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "verdict": {
      "type": "string",
      "enum": ["APPROVED", "CHANGES_REQUIRED", "REVIEW_FAILED"]
    },
    "reviewed_base": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_head": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_diff_hash": {
      "type": "string",
      "minLength": 1,
      "description": "SHA256 hex digest of canonical UTF-8 (no BOM) diff bytes"
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "category",
        "file",
        "line_start",
        "line_end",
        "problem",
        "evidence",
        "required_fix"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["BLOCKER", "MAJOR", "MINOR"]
        },
        "category": {
          "type": "string",
          "enum": [
            "CORRECTNESS",
            "SECURITY",
            "DATA_INTEGRITY",
            "DETERMINISM",
            "TESTING",
            "ARCHITECTURE",
            "DOCUMENTATION"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        },
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "required_fix": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
